# =========================================================================
# Bacoola — Next.js storefront environment template
# Copy this file to `.env.local` and fill in the values. `.env.local` is
# gitignored. All values here are safe to expose to the browser.
# =========================================================================

# Publishable API key from the Medusa backend. Required for the storefront to
# fetch data. It is created by the seed script / admin; paste it here after
# seeding (see README).
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=

# URL of the Medusa backend API server.
NEXT_PUBLIC_MEDUSA_BACKEND_URL=http://localhost:9000

# Default region code (must match the country of a seeded region).
NEXT_PUBLIC_DEFAULT_REGION=us

# Base URL of the storefront (used for generating absolute URLs).
NEXT_PUBLIC_BASE_URL=http://localhost:8000

# Stripe publishable key (optional, only if using Stripe payments).
NEXT_PUBLIC_STRIPE_KEY=

# Node environment.
NODE_ENV=development
